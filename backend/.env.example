# DB
DATABASE_URL=sqlite:///./receipt.db

# CORS (콤마 구분)
CORS_ORIGINS=http://localhost:3000

# 업로드
UPLOAD_DIR=./storage/receipts
MAX_UPLOAD_SIZE_MB=10

# OCR provider: null | upstage
OCR_PROVIDER=null

# Upstage OCR (provider=upstage 일 때만 사용)
UPSTAGE_API_KEY=
UPSTAGE_API_BASE=https://api.upstage.ai/v1
UPSTAGE_OCR_MODEL=information-extract
UPSTAGE_TIMEOUT_SECONDS=60

# 앱
APP_ENV=development
LOG_LEVEL=INFO
